# --- محرك توليد UIDs المليوني (Targeted Ranges) ---
class UIDGenerator:
    @staticmethod
    def generate(year):
        if year == "2009":
            # نطاق 2009 يبدأ بـ 100000000 إلى 100000500 تقريباً
            return "10000" + str(random.randint(100000, 999999))
        elif year == "2010":
            # نطاق 2010 يبدأ بـ 100000500 إلى 100001000 تقريباً
            return "10000" + str(random.randint(1000000, 9999999))
        elif year == "2011-2014":
            # نطاق 2011 وما فوق يبدأ بـ 100002... 100008...
            prefixes = ["100002", "100003", "100004", "100005", "100006", "100007", "100008"]
            return random.choice(prefixes) + str(random.randint(1000000, 9999999))
        return "1000" + str(random.randint(111111111, 999999999))

