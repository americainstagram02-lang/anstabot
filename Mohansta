class InstagramCore:
    def __init__(self, session_id):
        self.session_id = session_id
        self.user_agent = generate_user_agent()
        self.headers = {
            'Host': 'i.instagram.com',
            'sec-ch-ua': '"Google Chrome";v="110", "Not)A;Brand";v="8", "Chromium";v="110"',
            'x-ig-app-id': '1217981644879628',
            'x-ig-www-claim': 'hmac.AR2OtYWgs8__K9u4lq6KcsuD0AlWEdc1PA7pCmaUcXWp7UgT',
            'sec-ch-ua-mobile': '?1',
            'x-instagram-ajax': '1006192243',
            'accept': '*/*',
            'user-agent': self.user_agent,
            'x-asbd-id': '198387',
            'x-csrftoken': '2C8OLRCvFdI6PLg9i23yGt7oQkFoGRbh',
            'sec-ch-ua-platform': '"Android"',
            'origin': 'https://www.instagram.com',
            'sec-fetch-site': 'same-site',
            'sec-fetch-mode': 'cors',
            'sec-fetch-dest': 'empty',
            'referer': 'https://www.instagram.com/',
            'cookie': f'sessionid={self.session_id}'
        }

    def get_user_data(self, username):
        try:
            url = f"https://www.instagram.com/{username}/?__a=1&__d=dis"
            response = requests.get(url, headers=self.headers, timeout=10)
            if response.status_code == 200:
                data = response.json()
                user_id = data["graphql"]["user"]["id"]
                return user_id
            return None
        except Exception:
            return None

    def fetch_reels_tray(self):
        try:
            url = "https://i.instagram.com/api/v1/feed/reels_tray/"
            response = requests.get(url, headers=self.headers, timeout=10)
            if response.status_code == 200:
                return response.json()
            return None
        except Exception:
            return None

    def fetch_user_stories(self, user_id):
        try:
            url = f"https://i.instagram.com/api/v1/feed/reels_media/?reel_ids={user_id}"
            response = requests.get(url, headers=self.headers, timeout=10)
            if response.status_code == 200:
                return response.json()
            return None
        except Exception:
            return None

    def mark_story_seen(self, reel_id, owner_id, taken_at):
        try:
            url = "https://i.instagram.com/api/v1/stories/reel/seen"
            payload = {
                "reelMediaId": str(reel_id),
                "reelMediaOwnerId": str(owner_id),
                "reelId": str(owner_id),
                "reelMediaTakenAt": str(taken_at),
                "viewSeenAt": str(taken_at)
            }
            response = requests.post(url, headers=self.headers, data=payload, timeout=10)
            if response.status_code == 200:
                return response.json().get("status") == "ok"
            return False
        except Exception:
            return False

class MohaEngine:
    def __init__(self, session_id):
        self.core = InstagramCore(session_id)
        self.success_count = 0
        self.fail_count = 0

    def process_followers_stories(self):
        MohaLuxuryUI.print_status("info", "Fetching stories from your feed...")
        data = self.core.fetch_reels_tray()
        if not data or 'tray' not in data:
            MohaLuxuryUI.print_status("error", "Could not fetch feed. Check Session ID.")
            return

        for entry in data['tray']:
            try:
                username = entry['user']['username']
                owner_id = entry['id']
                latest_reel = entry.get('latest_reel_media')
                
                if latest_reel:
                    stories_data = self.core.fetch_user_stories(owner_id)
                    if stories_data and 'reels' in stories_data:
                        items = stories_data['reels'][owner_id]['items']
                        for item in items:
                            media_id = item['pk']
                            taken_at = item['taken_at']
                            if self.core.mark_story_seen(media_id, owner_id, taken_at):
                                self.success_count += 1
                                MohaLuxuryUI.print_status("success", f"Watched: @{username}")
                            else:
                                self.fail_count += 1
                            time.sleep(random.uniform(1.5, 3.5))
            except Exception:
                continue

    def process_list_stories(self, user_list):
        for username in user_list:
            MohaLuxuryUI.print_status("wait", f"Checking stories for @{username}...")
            user_id = self.core.get_user_data(username)
            if user_id:
                stories_data = self.core.fetch_user_stories(user_id)
                if stories_data and 'reels' in stories_data and user_id in stories_data['reels']:
                    items = stories_data['reels'][user_id]['items']
                    for item in items:
                        media_id = item['pk']
                        taken_at = item['taken_at']
                        if self.core.mark_story_seen(media_id, user_id, taken_at):
                            self.success_count += 1
                            MohaLuxuryUI.print_status("success", f"Watched: @{username}")
                        time.sleep(random.uniform(2.0, 4.0))
                else:
                    MohaLuxuryUI.print_status("info", f"No active stories for @{username}")
            else:
                MohaLuxuryUI.print_status("error", f"User @{username} not found.")
            time.sleep(random.uniform(1.0, 2.0))

